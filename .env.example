# ============================================================
# WordPress REST API
# ============================================================
NEXT_PUBLIC_WORDPRESS_URL=http://localhost:10004

# ============================================================
# WooCommerce REST API
# Generate keys: WooCommerce → Settings → Advanced → REST API → Create Key
# ============================================================
WOOCOMMERCE_CONSUMER_KEY=ck_your_consumer_key_here
WOOCOMMERCE_CONSUMER_SECRET=cs_your_consumer_secret_here

# ============================================================
# ISR Revalidation (seconds)
# 60 = 1 min (dev) | 3600 = 1 hour (production)
# ============================================================
NEXT_PUBLIC_ISR_REVALIDATE=60

# ============================================================
# Site Info
# ============================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Songdian Technology — Digital Camera OEM/ODM Manufacturer
NEXT_PUBLIC_SITE_DESCRIPTION=Songdian Technology (松典) — 19 years of digital camera manufacturing. 30+ new products/year, 8,000 units daily output, 500+ patents. OEM/ODM partner for global brands.

# ============================================================
# SMTP Email（询盘通知）
# 填写以下 4 项启用邮件通知；不填则仅保存到 data/inquiries.json
# ============================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# 接收询盘通知的邮箱（默认 zengxb21@proton.me）
INQUIRY_EMAIL_TO=zengxb21@proton.me
# 发件人地址（默认取 SMTP_USER）
# INQUIRY_EMAIL_FROM=noreply@songdian.com
